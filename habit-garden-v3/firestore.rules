rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS ──────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /peers/{peerId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── HABITS ─────────────────────────────────────────────────
    match /habits/{habitId} {
      allow read: if request.auth != null && (
        resource.data.visibility == 'public' ||
        resource.data.ownerId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // ── PLANTS ─────────────────────────────────────────────────
    match /plants/{plantId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // ── COMPLETIONS (moments) ──────────────────────────────────
    match /completions/{completionId} {
      allow read: if request.auth != null && (
        resource.data.visibility == 'public' ||
        resource.data.visibility == 'peers' ||
        resource.data.userId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── LIKES ──────────────────────────────────────────────────
    match /likes/{likeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid in likeId.split('_');
    }

    // ── COMMENTS ───────────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── PEER REQUESTS ──────────────────────────────────────────
    match /peerRequests/{reqId} {
      allow read: if request.auth != null && (
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
      allow update: if request.auth != null && resource.data.to == request.auth.uid;
    }

    // ── NOTIFICATIONS ──────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if request.auth != null && resource.data.toUid == request.auth.uid;
      allow update: if request.auth != null && resource.data.toUid == request.auth.uid;
      // Write only by server (Cloud Functions) — no direct client writes
    }

    // ── LEADERBOARD (read-only for clients) ────────────────────
    match /leaderboard/{entryId} {
      allow read: if request.auth != null;
      // Written only by Cloud Functions
    }

    // ── TRYBES (groups) ────────────────────────────────────────
    match /trybes/{trybeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.memberIds
      );
    }

    match /trybes/{trybeId}/members/{memberId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == memberId;
    }
  }
}
